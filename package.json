{
  "name": "hr-gestpro-2.0",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.js",
  "build": {
    "appId": "com.hrtecnologias.gestpro",
    "productName": "HR-GESTPRO",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "public/vite.svg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder --win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
