{
  "name": "hr-gestpro-2.0",
  "private": true,
  "version": "2.1.1",
  "main": "electron/main.js",
  "build": {
    "appId": "com.hrtecnologias.gestpro",
    "productName": "HR-GESTPRO",
    "copyright": "Copyright © 2026 HR Tecnologias",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HR-GESTPRO 2.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:all": "vite build && electron-builder --win --linux",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.13",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}